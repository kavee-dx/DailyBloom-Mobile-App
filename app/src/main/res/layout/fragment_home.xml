<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 👋 Greeting & Profile Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp"
            android:gravity="center_vertical">

            <!-- Profile Picture -->
            <ImageView
                android:id="@+id/profileImageView"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_profile_placeholder"
                android:background="@drawable/profile_pic_background"
                android:scaleType="centerInside"
                android:padding="12dp"
                android:layout_marginEnd="16dp" />

            <!-- User Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/userNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/placeholder_welcome"
                    android:textColor="@color/textColorPrimary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/greetingText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:text="@string/home_good_morning"
                    android:textColor="@color/textColorSecondary"
                    android:textSize="16sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- 🌸 App Logo and Name Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="20dp"
            android:padding="16dp">

            <ImageView
                android:id="@+id/appLogoImageView"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/lotus_flower"
                android:scaleType="centerInside"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/appNameTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:text="DailyBloom"
                android:textColor="@color/primaryColor"
                android:textSize="28sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- ✨ Daily Motivation Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/motivation_card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/home_daily_motivation"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/motivationQuote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0.9"
                android:fontFamily="sans-serif"
                android:lineSpacingExtra="2dp"
                android:text="@string/motivation_quote_1"
                android:textColor="@color/white"
                android:textSize="18sp" />

        </LinearLayout>


        <!-- 📊 Today's Progress Summary -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp">

            <!-- Habits Progress Box -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/habitsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/habits_card_color"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎯"
                            android:textSize="24sp"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-medium"
                            android:text="Today's Habits"
                            android:textColor="@color/black"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→"
                            android:textSize="20sp"
                            android:textColor="@color/white"
                            android:alpha="0.7" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/habitsProgressText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="3/5 habits completed"
                        android:textColor="@color/black"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/habitsPercentageText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:alpha="0.8"
                        android:text="60% Complete"
                        android:textColor="@color/black"
                        android:textSize="18sp" />

                    <!-- Progress Bar -->
                    <ProgressBar
                        android:id="@+id/habitsProgressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:alpha="0.3"
                        android:backgroundTint="@color/textColorSecondary"
                        android:max="100"
                        android:progress="60"
                        android:progressTint="@color/primaryColor" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Hydration Progress Box -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/hydrationCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/hydration_card_color"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💧"
                            android:textSize="24sp"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-medium"
                            android:text="Hydration"
                            android:textColor="@color/black"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→"
                            android:textSize="20sp"
                            android:textColor="@color/black"
                            android:alpha="0.7" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/hydrationStatusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="6/8 glasses today"
                        android:textColor="@color/black"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/hydrationPercentageText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="75% Complete"
                        android:textSize="18sp"
                        android:textColor="@color/black"
                        android:alpha="0.8"
                        android:layout_marginBottom="8dp" />

                    <!-- Progress Bar -->
                    <ProgressBar
                        android:id="@+id/hydrationProgressBar"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:progress="75"
                        android:max="100"
                        android:progressTint="@color/primaryColor"
                        android:backgroundTint="@color/textColorSecondary"
                        android:alpha="0.3" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Mood Progress Box -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/moodCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/mood_card_color"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="😊"
                            android:textSize="24sp"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Mood Tracking"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/black"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→"
                            android:textSize="20sp"
                            android:textColor="@color/black"
                            android:alpha="0.7" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/moodStatusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Today's mood: Happy 😊"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/moodStreakText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="7 day streak!"
                        android:textSize="18sp"
                        android:textColor="@color/black"
                        android:alpha="0.8"
                        android:layout_marginBottom="8dp" />

                    <!-- Progress Bar -->
                    <ProgressBar
                        android:id="@+id/moodProgressBar"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:progress="100"
                        android:max="100"
                        android:progressTint="@color/primaryColor"
                        android:backgroundTint="@color/textColorSecondary"
                        android:alpha="0.3" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
